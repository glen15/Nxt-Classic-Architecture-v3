# DB_TYPE: sqlite (기본값) 또는 mysql
DB_TYPE=sqlite

# SERVER_PORT (기본값: 8000)
# SERVER_PORT=8000

# 삭제 비밀번호 (미설정 시 비밀번호 없이 삭제 가능)
ADMIN_PASSWORD=1234

# SQLite 경로 (DB_TYPE=sqlite 일 때, 기본값: ./data.db)
# SQLITE_PATH=./data.db

# MySQL 설정 (DB_TYPE=mysql 일 때)
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
